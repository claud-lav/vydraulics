{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "craftcms/ckeditor": "^4.2.0",
    "craftcms/cms": "^5.9.0",
    "craftcms/postmark": "^3.1.0",
    "mutation/translate": "^4.2.1",
    "nystudio107/craft-retour": "^5.0.3",
    "nystudio107/craft-seomatic": "^5.1.2",
    "nystudio107/craft-vite": "^5.0.1",
    "putyourlightson/craft-sprig": "^3.4.0",
    "spacecatninja/imager-x": "^5.0.2",
    "verbb/formie": "^3.1.5",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.0.0",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example.dev', '.env');\""
    ]
  },
  "autoload": {
    "psr-4": {
      "modules\\slugrefresh\\": "modules/slugrefresh/",
      "modules\\languageredirect\\": "modules/languageredirect/",
      "modules\\linkresolver\\": "modules/linkresolver/"
    }
  }
}
