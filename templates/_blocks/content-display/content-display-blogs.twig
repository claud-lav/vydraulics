{% set showSome = showSome ?? section.showSome ?? false %}

{% if showSome %}
	{% set link = link ?? section.linkField ?? null %}
	{% set url = url ?? null %}
	{% set linkBtnTitle = linkBtnTitle ?? null %}
    {% set linkTitle = linkTitle ?? section.linkTitle ?? null %}
    {% set title = title ?? section.title ?? null %}
	{% set blogs = craft.entries().section('blog').with(['img']).limit(3).all() %}
	{% set firstBlog = blogs|slice(0, 1)|first %}
	{% set otherBlogs = blogs|slice(1, 2) %}
    {% set withBg = withBg ?? null %}

	<section class="section">
		<div class="container container-grid items-center {{ withBg ? 'bg-white py-2xl rounded-base' }}">
			<div class="col-start-2 col-span-4">
				{% include "_components/title" with { title: title, extraClass: 'mb-md'} %}
				<a href="{{ firstBlog.url }}" class="card-blog group">
					<div>
						<div class="rounded-base overflow-hidden">
							{% if firstBlog.img.one() %}
								{% include "_components/asset" with { asset: firstBlog.img.one(), class: "card-blog-img" } %}
							{% endif %}
						</div>
						<div class="flex flex-row items-end justify-between w-full mt-sm">
							<h3 class="w-[60%] font-bold font-heading text-sm">{{ firstBlog.title }}</h3>
							{% include "_components/link" with { noLink: true, label: 'Read more'|t, withArrow: true, noBorderAnimation: true, extraClass: 'text-prim' } %}
						</div>
					</div>
				</a>
				{% if link or url %}
					<div class="mt-xl">
						<h3>{{ linkTitle }}</h3>
                        {% if link %}
						    {% include "_components/link" with { linkField: link, btnStyle: true, withBg: true, withArrow: true, extraClass: 'mt-base' } %}
                        {% endif %}
                        {% if url %}
						    {% include "_components/link" with { url: url, label: linkBtnTitle, btnStyle: true, withBg: true, withArrow: true, extraClass: 'mt-base' } %}
                        {% endif %}
					</div>
				{% endif %}
			</div>
			<div class="col-start-8 col-span-4 flex flex-col gap-2xl">
				{% for item in otherBlogs %}
					<a href="{{ item.url }}" class="group card-blog">
						<div>
							<div class="rounded-base overflow-hidden">
								{% if item.img.one() %}
									{% include "_components/asset" with { asset: item.img.one(), class: "card-blog-img" } %}
								{% endif %}
							</div>
							<div class="flex flex-row items-end justify-between w-full mt-sm">
								<h3 class="w-[60%] font-bold font-heading text-sm">{{ item.title }}</h3>
								{% include "_components/link" with { noLink: true, label: 'Read more'|t, withArrow: true, extraClass: 'text-prim', noBorderAnimation: true } %}
							</div>
						</div>
					</a>
				{% endfor %}
			</div>
		</div>
	</section>
{% else %}
	{{ sprig('_sprig-components/blogs')}}
{% endif %}
