{% set gridItems = section.gridItems.all() %}

{% set rowClasses = {
    1: 'grid-rows-1',
    2: 'md:grid-rows-2',
    3: 'md:grid-rows-3',
    4: 'md:grid-rows-4'
} %}

{% set colClasses = {
    1: 'grid-cols-1',
    2: 'md:grid-cols-2',
    3: 'md:grid-cols-3',
    4: 'sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
} %}

<section class="section">
    <div class="container">
        {% include "_components/title" with { title: section.title } %}
        {% if gridItems|length %}
            <div class="grid gap-1 {{ [colClasses[section.gridCols.value|integer] ?? null]|filter|join(' ') }} {{ [rowClasses[section.gridRows.value|integer] ?? null]|filter|join(' ') }}">
                {% for item in gridItems %}
                    {% include "_components/card" with {
                        title: item.title,
                        text: item.textMultiple,
                        img: item.img.one(),
                        graphic: item.graphic.one(),
                        link: item.linkField,
                        rowSpan: item.rowSpan.value,
                        colSpan: item.colSpan.value,
                    } %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>