{#
    Base Email Layout

    Variables that should be set before including:
    - siteHandle: string (e.g., "petrusNl", "kwaremontNl") - site handle to query data from
    - brandName: string (e.g., "Petrus", "Kwaremont")
    - headerBgColor: string (hex color for header background)
    - footerBgColor: string (hex color for footer background)
    - footerTextColor: string (hex color for footer text)
    - footerLinkColor: string (hex color for footer links)
    - footerMutedColor: string (hex color for muted footer text)
    - footerBorderColor: string (hex color for footer border)
    - bodyBgColor: string (hex color for body/outer background)
    - contentBgColor: string (hex color for content area)
    - textColor: string (hex color for body text)
    - fontFamily: string (font-family for email)
#}

{# Use siteHandle variable if set, otherwise fall back to currentSite #}
{% set emailSite = siteHandle is defined ? siteHandle : currentSite %}

{# Explicitly query singles for the specified site to ensure correct data in emails #}
{% set brandInfo = craft.entries.section('brandInfo').site(emailSite).one() %}
{% set companyInfo = craft.entries.section('companyInfo').site(emailSite).one() %}

{% set address = companyInfo.address.one() ?? null %}
{% set socials = seomatic.site.sameAsLinks ?? [] %}

{# Default values if not set #}
{% set brandName = brandName ?? 'Brouwerij De Brabandere' %}
{% set headerBgColor = headerBgColor ?? '#1D1C47' %}
{% set footerBgColor = footerBgColor ?? '#1D1C47' %}
{% set footerTextColor = footerTextColor ?? '#ffffff' %}
{% set footerLinkColor = footerLinkColor ?? '#ffffff' %}
{% set footerMutedColor = footerMutedColor ?? '#cccccc' %}
{% set footerBorderColor = footerBorderColor ?? '#333333' %}
{% set bodyBgColor = bodyBgColor ?? '#f4f4f4' %}
{% set contentBgColor = contentBgColor ?? '#ffffff' %}
{% set textColor = textColor ?? '#1D1C47' %}
{% set fontFamily = fontFamily ?? 'Arial, sans-serif' %}

<!DOCTYPE html>
<html lang="nl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="color-scheme" content="light only">
        <meta name="x-apple-disable-message-reformatting">
        <title>{{ subject ?? 'Email' }}</title>
        <!--[if mso]>
        <style type="text/css">
            table { border-collapse: collapse; }
            td { padding: 0; }
        </style>
        <![endif]-->
        <style type="text/css">
            p { margin: 0 0 12px 0; }
            @media only screen and (max-width: 620px) {
                .email-container {
                    width: 100% !important;
                }
                .mobile-padding {
                    padding-left: 20px !important;
                    padding-right: 20px !important;
                }
            }
        </style>
    </head>
    <body style="margin: 0; padding: 0; background-color: {{ bodyBgColor }}; font-family: {{ fontFamily }}; font-size: 16px; line-height: 1.5; color: {{ textColor }};">
        <!--[if mso]>
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: {{ bodyBgColor }};">
        <tr><td align="center">
        <![endif]-->
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: {{ bodyBgColor }};">
            <tr>
                <td align="center" style="padding: 20px 10px;">
                    <!--[if mso]>
                    <table role="presentation" cellpadding="0" cellspacing="0" width="600" align="center">
                    <tr><td>
                    <![endif]-->
                    <table role="presentation" cellpadding="0" cellspacing="0" width="600" class="email-container" style="max-width: 600px; width: 100%; background-color: {{ contentBgColor }};">

                        {# Header met logo #}
                        <tr>
                            <td class="mobile-padding" style="padding: 30px 40px; background-color: {{ headerBgColor }};">
                                {% if brandInfo.brandLogoEmail.one() %}
                                    <img src="{{ brandInfo.brandLogoEmail.one().url }}" alt="{{ brandName }}" title="{{ brandName }}" width="120" height="auto" style="display: block; border: 0; max-height: 60px; width: auto;">
                                {% endif %}
                            </td>
                        </tr>

                        {# Content #}
                        <tr>
                            <td class="mobile-padding" style="padding: 40px;">
                                {% block content %}{% endblock %}
                            </td>
                        </tr>

                        {# Footer #}
                        <tr>
                            <td class="mobile-padding" style="padding: 30px 40px; background-color: {{ footerBgColor }}; color: {{ footerTextColor }};">
                                <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                    <tr>
                                        <td style="padding-bottom: 20px;">
                                            <p style="margin: 0; font-weight: bold; font-size: 16px; color: {{ footerTextColor }};">{{ brandName }}</p>
                                            <p style="margin: 5px 0 0 0; font-size: 14px; color: {{ footerMutedColor }};">
                                                {{ address ? address.addressLine1 : 'Rijksweg 33' }}<br>
                                                {{ address ? address.postalCode : '8531' }} {{ address ? address.locality : 'Bavikhove' }}<br>
                                                {{ 'België'|t }}
                                            </p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding-bottom: 20px;">
                                            <p style="margin: 0; font-size: 14px; color: {{ footerMutedColor }};">
                                                {% if companyInfo.eMail ?? null %}
                                                    <a href="mailto:{{ companyInfo.eMail }}" style="color: {{ footerLinkColor }}; text-decoration: none;">{{ companyInfo.eMail }}</a><br>
                                                {% endif %}
                                                {% if companyInfo.tels is defined and companyInfo.tels|length %}
                                                    {% set firstTel = companyInfo.tels|first %}
                                                    <a href="tel:{{ firstTel.tel }}" style="color: {{ footerLinkColor }}; text-decoration: none;">{{ firstTel.tel }}</a>
                                                {% endif %}
                                            </p>
                                        </td>
                                    </tr>
                                    {% if socials|length %}
                                        <tr>
                                            <td style="padding-bottom: 20px;">
                                                {% for item in socials %}
                                                    {% if item.url %}
                                                        <a href="{{ item.url }}" target="_blank" style="display: inline-block; margin-right: 10px; color: {{ footerLinkColor }}; text-decoration: none; font-size: 14px;">{{ item.siteName ?? item.handle|capitalize }}</a>
                                                    {% endif %}
                                                {% endfor %}
                                            </td>
                                        </tr>
                                    {% endif %}
                                    <tr>
                                        <td style="border-top: 1px solid {{ footerBorderColor }}; padding-top: 20px;">
                                            <p style="margin: 0; font-size: 12px; color: {{ footerMutedColor|replace({'#ffffff': '#888888', '#EAE6D7': '#888888'})|default('#888888') }};">
                                                {{ companyInfo.btwNum ?? 'BE0442443823' }}<br>
                                                <a href="{{ siteUrl() }}" style="color: {{ footerMutedColor|replace({'#ffffff': '#888888', '#EAE6D7': '#888888'})|default('#888888') }}; text-decoration: underline;">{{ siteUrl() }}</a>
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>

                    </table>
                    <!--[if mso]>
                    </td></tr>
                    </table>
                    <![endif]-->
                </td>
            </tr>
        </table>
        <!--[if mso]>
        </td></tr>
        </table>
        <![endif]-->
    </body>
</html>
